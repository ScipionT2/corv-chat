# Nova Web — Environment Variables
# Copy to .env and fill in your keys.

# At least one API key is required:
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Default model (optional — auto-detected from available provider)
# Examples: openrouter/auto, gpt-4o-mini, anthropic/claude-sonnet-4, etc.
NOVA_DEFAULT_MODEL=

# Server port (default 8766)
PORT=8766

# Nova system prompt override (optional)
NOVA_SYSTEM_PROMPT=
