# Jarvis Voice Bridge — Environment Configuration
# Copy to .env and customise as needed.

# Wake word
# JARVIS_WAKE_WORD=jarvis
# JARVIS_WAKE_CONFIDENCE=0.5

# Audio
# JARVIS_SAMPLE_RATE=16000
# JARVIS_CHUNK_SAMPLES=1280

# Recording / VAD
# JARVIS_SILENCE_MS=500
# JARVIS_SILENCE_ENERGY=0.01
# JARVIS_MAX_RECORD_SEC=30

# Whisper STT
# JARVIS_WHISPER_MODEL=base.en
# JARVIS_WHISPER_DEVICE=cpu
# JARVIS_WHISPER_COMPUTE=int8

# Ollama LLM
# JARVIS_OLLAMA_URL=http://localhost:11434
# JARVIS_OLLAMA_MODEL=qwen2.5-coder:7b
# JARVIS_OLLAMA_TIMEOUT=120

# System prompt
# JARVIS_SYSTEM_PROMPT=You are Jarvis, a helpful local AI assistant.

# Conversation history (number of exchange pairs)
# JARVIS_MAX_HISTORY=10

# TTS
# JARVIS_TTS_BACKEND=auto
# JARVIS_PIPER_VOICE=en_US-lessac-medium
# JARVIS_SAY_VOICE=Samantha

# Activation sound
# JARVIS_BLIP_FREQ=880
# JARVIS_BLIP_DURATION_MS=150

# Logging
# JARVIS_LOG_LEVEL=INFO
