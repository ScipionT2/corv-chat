# Nova — Environment Configuration
# Copy to .env and customize as needed.
# Or set your API key during first-run onboarding.

# ─── Cloud Provider (OpenRouter) ───
# Get your free key at https://openrouter.ai/keys
# Enables Claude, GPT-4o, Gemini, Llama, Mistral, and 200+ models
# NOVA_OPENROUTER_API_KEY=sk-or-...

# Cloud model (via OpenRouter). Default: anthropic/claude-sonnet-4
# NOVA_OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Provider priority (comma-separated). Default: openrouter,openai,ollama
# NOVA_PROVIDER_PRIORITY=openrouter,openai,ollama

# ─── Local Model (Ollama) ───
# NOVA_OLLAMA_URL=http://localhost:11434
# NOVA_OLLAMA_MODEL=qwen2.5:3b
# NOVA_OLLAMA_TIMEOUT=30

# ─── Wake Word ───
# NOVA_WAKE_WORD=nova
# NOVA_WAKE_CONFIDENCE=0.5

# ─── Voice ───
# NOVA_SAY_VOICE=Daniel
# NOVA_TTS_BACKEND=auto

# ─── Vision ───
# NOVA_VISION=true
# NOVA_VISION_MODEL=moondream:1.8b

# ─── Web Control Hub ───
# NOVA_WEB_PORT=8766

# ─── Logging ───
# NOVA_LOG_LEVEL=INFO
